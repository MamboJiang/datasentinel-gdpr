# DataSentinel local runtime settings.
# Copy to .env.local on the server or workstation. .env.local is ignored by git.

# off | assistive
DATASENTINEL_AI_MODE=assistive

# OpenRouter secret. Never commit a real key.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=https://founder-force.uk/
OPENROUTER_APP_TITLE=DataSentinel GDPR

# OpenRouter bills in USD credits. This keeps the project below the requested
# 25 EUR budget by using a conservative 25 USD application cap.
DATASENTINEL_AI_BUDGET_EUR=25.00
DATASENTINEL_AI_BUDGET_USD=25.00
OPENROUTER_USAGE_BASELINE_USD=

# Fail closed means no AI calls are made if usage cannot be checked.
DATASENTINEL_AI_FAIL_CLOSED=true
DATASENTINEL_AI_TIMEOUT_SECONDS=20
DATASENTINEL_AI_MAX_PROMPT_TOKENS=6000
DATASENTINEL_AI_MAX_COMPLETION_TOKENS=350

# deferred | local
# local requires the tesseract CLI to be installed on the host.
DATASENTINEL_OCR_MODE=deferred

# Prelaunch account system.
# Set DATASENTINEL_AUTH_REQUIRED=true on shared preview/prelaunch hosts.
DATASENTINEL_AUTH_REQUIRED=false
DATASENTINEL_AUTH_REDIRECT_BASE_URL=http://localhost:8000
DATASENTINEL_FRONTEND_RETURN_URL=http://localhost:5173/dashboard
DATASENTINEL_SESSION_SECRET=
DATASENTINEL_COOKIE_SECURE=false
DATASENTINEL_ENABLE_DEMO_FIXTURES=false

# Google OAuth web application credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Drive Picker public setup. Keep in ignored host env for rotation.
GOOGLE_PICKER_API_KEY=
GOOGLE_CLOUD_PROJECT_NUMBER=

# GitHub OAuth app credentials.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
