# lawdit local runtime settings.
# Copy to .env.local on the server or workstation. .env.local is ignored by git.

# off | assistive
LAWDIT_AI_MODE=assistive

# OpenRouter secret. Never commit a real key.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=https://founder-force.uk/
OPENROUTER_APP_TITLE=lawdit GDPR

# OpenRouter bills in USD credits. This keeps the project below the requested
# 25 EUR budget by using a conservative 25 USD application cap.
LAWDIT_AI_BUDGET_EUR=25.00
LAWDIT_AI_BUDGET_USD=25.00
OPENROUTER_USAGE_BASELINE_USD=

# Fail closed means no AI calls are made if usage cannot be checked.
LAWDIT_AI_FAIL_CLOSED=true
LAWDIT_AI_TIMEOUT_SECONDS=20
LAWDIT_AI_MAX_PROMPT_TOKENS=6000
LAWDIT_AI_MAX_COMPLETION_TOKENS=350

# deferred | local
# local requires the tesseract CLI to be installed on the host.
LAWDIT_OCR_MODE=deferred
# Optional Tesseract language list, for example eng+chi_sim+deu+fra+spa.
LAWDIT_OCR_LANGS=

# Prelaunch account system.
# Set LAWDIT_AUTH_REQUIRED=true on shared preview/prelaunch hosts.
LAWDIT_AUTH_REQUIRED=false
LAWDIT_AUTH_REDIRECT_BASE_URL=http://localhost:8000
LAWDIT_FRONTEND_RETURN_URL=http://localhost:5173/dashboard
LAWDIT_SESSION_SECRET=
LAWDIT_COOKIE_SECURE=false
LAWDIT_ENABLE_DEMO_FIXTURES=false

# Google OAuth web application credentials.
# Authorized redirect URIs must include /api/auth/callback/google and
# /api/integrations/google-drive/bind/callback on the redirect base URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Drive Picker public setup. Keep in ignored host env for rotation.
GOOGLE_PICKER_API_KEY=
GOOGLE_CLOUD_PROJECT_NUMBER=

# GitHub OAuth app credentials.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
